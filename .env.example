# Copy this file to .env and fill in your LINE credentials.

# From LINE Developers Console → your Messaging API channel → "Channel access token (long-lived)"
LINE_CHANNEL_ACCESS_TOKEN=paste_your_long_lived_channel_access_token_here

# Your LINE user ID (Basic settings tab) OR a group/room ID.
# Multiple recipients: comma-separated. Example: Uxxxxx,Uyyyyy
LINE_TO=your_line_user_id_here
